DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,api.seudominio.com
CORS_ALLOWED_ORIGINS=https://seu-projeto.vercel.app
CSRF_TRUSTED_ORIGINS=https://seu-projeto.vercel.app

# Database (production: Supabase Postgres)
# Example: postgresql://postgres:password@db.xxxxx.supabase.co:5432/postgres
DATABASE_URL=
POSTGRES_SSLMODE=require

# Storage (local: False, production S3: True)
DJANGO_USE_S3=False
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=sa-east-1
AWS_LOCATION=media

# Discord webhook para notificar novo contato
DISCORD_CONTACT_WEBHOOK_URL=LINK_DO_SEU_WEBHOOK

# Webhook opcional para alertas de segurança (se vazio, usa o de contato)
DISCORD_SECURITY_WEBHOOK_URL=

# Monitoramento básico de segurança
SECURITY_ALERTS_ENABLED=True
SECURITY_ALERTS_RATE_LIMIT_PER_MINUTE=120

# Bloqueio ativo no endpoint de contato (DRF throttle por IP)
CONTACT_MESSAGE_THROTTLE_RATE=5/minute
